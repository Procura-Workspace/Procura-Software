{
  "name": "procura",
  "private": true,
  "version": "0.1.0",
  "description": "Procura - plateforme Source-to-Contract on-premise",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @procura/shared build && pnpm --parallel --filter @procura/api --filter @procura/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "format": "prettier --write .",
    "prepare": "husky",
    "openapi:generate": "pnpm --filter @procura/api export-openapi"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.16.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0"
  }
}
