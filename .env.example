# Environment Mode
NODE_ENV=development

# Fastify API Server Config
API_HOST=0.0.0.0
API_PORT=8080
WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database configuration
POSTGRES_DB=procura
POSTGRES_USER=procura
POSTGRES_PASSWORD=generate_a_secure_password_here
# Note: local dev server outside Docker uses localhost:5433 (mapping to Docker container)
DATABASE_URL=postgresql://procura:generate_a_secure_password_here@localhost:5433/procura

# Redis configuration
REDIS_URL=redis://localhost:6379

# MinIO Object Storage
MINIO_ROOT_USER=procura_admin
MINIO_ROOT_PASSWORD=generate_another_secure_password_here
MINIO_KMS_SECRET_KEY=procura-kms-key:yS3aX4q2Z9mK0cO1tN7sE6jR4wV8xY2zL1oP5uI6aT8=

# HashiCorp Vault
VAULT_DEV_ROOT_TOKEN_ID=generate_a_random_token_here

# Security Secrets (Must be at least 32 characters for JWT, 12 characters for Audit Pepper)
JWT_SECRET=generate_a_random_cryptographic_secret_here
AUDIT_HASH_PEPPER=generate_a_secure_audit_pepper_here

# LDAP / Active Directory Integration
LDAP_URL=ldaps://localhost:636
LDAP_BIND_DN=cn=admin,dc=procura,dc=local
LDAP_BIND_PASSWORD=admin_password
